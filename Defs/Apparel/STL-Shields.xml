<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--==================================== STL-Shields Mk.1 ====================================-->

  <ThingDef ParentName="ApparelBase">
    <defName>STL-Shields_Mk1_dayo</defName>
    <label>STL-Shields Mk.1</label>
    <description>.</description>
    <thingClass>Apparel</thingClass>
    <graphicData>
      <texPath>Things/Item/Equipment/Utility/STL-ShieldBelt_Mk.1</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tickerType>Normal</tickerType>
    <techLevel>Spacer</techLevel>
    <statBases>
      <Mass>3</Mass>
      <WorkToMake>60000</WorkToMake>
      <Flammability>0.4</Flammability>
      <EnergyShieldRechargeRate>3.20</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>4.00</EnergyShieldEnergyMax>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <thingSetMakerTags>
      <li>RewardStandardQualitySuper</li>
    </thingSetMakerTags>
    <costList>
      <ComponentSpacer>1</ComponentSpacer>
      <ComponentIndustrial>5</ComponentIndustrial>
      <Steel>600</Steel>
      <Plasteel>120</Plasteel>
    </costList>
    <recipeMaker>
      <unfinishedThingDef>UnfinishedBelt</unfinishedThingDef>
      <researchPrerequisite>STL-ShieldBelt_Mk1_Resarch</researchPrerequisite>
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Smith</effectWorking>
      <soundWorking>Recipe_Machining</soundWorking>
      <recipeUsers>
        <li>STL-CraftingTable</li>
      </recipeUsers>
      <useIngredientsForColor>false</useIngredientsForColor>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <displayPriority>300</displayPriority>
    </recipeMaker>
    <thingCategories>
      <li>ApparelUtility</li>
    </thingCategories>
    <apparel>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <careIfWornByCorpse>false</careIfWornByCorpse>
      <careIfDamaged>false</careIfDamaged>
      <wearPerDay>0</wearPerDay>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <tags>
        <li>BeltDefense</li>
      </tags>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
      </options>
    </colorGenerator>
    <comps>
      <li Class="Astrallium.CompProperties_AstralShield">
        <blocksEMP>true</blocksEMP>
        <empFullyDrains>false</empFullyDrains>
        <blocksMelee>true</blocksMelee>
        <blocksShieldPenetrating>true</blocksShieldPenetrating>
        <shieldPenetratingDamageDefs>
        </shieldPenetratingDamageDefs>
        <energyLossPerDamage>0.033</energyLossPerDamage>
        <blocksRangedWeapons>false</blocksRangedWeapons>
      </li>
    </comps>
    <allowedArchonexusCount>1</allowedArchonexusCount>
    <tradeTags>
      <li>Armor</li>
    </tradeTags>
  </ThingDef>

